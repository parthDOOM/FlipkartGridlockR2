# Copy this file to .env (never commit .env)

# PostgreSQL connection string
# Local dev (docker-compose):
DATABASE_URL=postgresql://admin:adminpassword@localhost:5432/congestion_db

# Cloud SQL (via Cloud SQL Auth Proxy on port 5433):
# DATABASE_URL=postgresql://gridlock_user:YOUR_PASSWORD@localhost:5433/congestion_db

# Cloud SQL (via Unix socket, inside Cloud Run):
# DATABASE_URL=postgresql+psycopg2://gridlock_user:YOUR_PASSWORD@/congestion_db?host=/cloudsql/PROJECT:REGION:INSTANCE

# CORS — comma-separated list of allowed origins, or * for any (dev only)
# Production: set to your Cloud Run URL
ALLOWED_ORIGINS=*
# ALLOWED_ORIGINS=https://gridlock-intelligence-abc123-uc.a.run.app
